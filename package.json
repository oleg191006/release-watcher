{
  "name": "release-watcher",
  "version": "1.0.0",
  "description": "GitHub Release Notification API ” subscribe to email notifications about new releases of GitHub repositories.",
  "main": "index.js",
  "scripts": {
    "start": "node -r module-alias/register src/server.js",
    "dev": "nodemon --exec \"node -r module-alias/register\" src/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:unit": "jest --runInBand --passWithNoTests",
    "test": "jest --coverage --forceExit --detectOpenHandles --passWithNoTests"
  },
  "_moduleAliases": {
    "@": "src"
  },
  "jest": {
    "setupFiles": [
      "module-alias/register"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "ioredis": "^5.4.1",
    "module-alias": "^2.3.4",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.14",
    "pg": "^8.12.0",
    "prom-client": "^15.1.3",
    "uuid": "^10.0.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-jest": "^29.15.2",
    "globals": "^15.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  }
}
